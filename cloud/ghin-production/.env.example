# GHIN Production API — Environment Variables

# Required: PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/ghin

# Server configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Optional: Redis for caching layer
# REDIS_URL=redis://localhost:6379

# Optional: OpenAI API key for LLM advisory features
# OPENAI_API_KEY=sk-...

# Optional: Rate limiting
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=60000

# Optional: CORS origin (default: *)
# CORS_ORIGIN=https://your-extension-domain.com
