# ═══════════════════════════════════════════════════════════════════════
# CodeGuard AI — Environment Variables
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your keys.
#   cp .env.example .env
#
# All services below have FREE TIERS sufficient for development and
# initial production use.
# ═══════════════════════════════════════════════════════════════════════

# ─── Supabase (PostgreSQL Database + Auth) ────────────────────────────
# Sign up: https://supabase.com (Free: 2 projects, 500 MB, 50K auth users)
# 1. Create a new project
# 2. Go to Settings → API → copy the URL and keys
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key

# Prisma database connection strings
# Go to Supabase → Settings → Database → Connection String → URI
# Replace [YOUR-PASSWORD] with your database password
DATABASE_URL=postgresql://postgres.[your-project-ref]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[your-project-ref]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ─── Upstash Redis (Rate Limiting + Caching) ─────────────────────────
# Sign up: https://upstash.com (Free: 10K commands/day, 256 MB)
# 1. Create a Redis database
# 2. Go to REST API tab → copy URL and token
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── GitHub OAuth (User Authentication) ──────────────────────────────
# Create: https://github.com/settings/applications/new
# 1. Application name: CodeGuard AI
# 2. Homepage URL: http://localhost:3000
# 3. Authorization callback URL: http://localhost:3000/api/auth/callback/github
#    (For production: https://your-domain.com/api/auth/callback/github)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ─── Sentry (Error Monitoring) ───────────────────────────────────────
# Sign up: https://sentry.io (Free: 5K events/month)
# 1. Create a Node.js project
# 2. Copy the DSN from the setup page
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ─── Resend (Email Notifications) ────────────────────────────────────
# Sign up: https://resend.com (Free: 100 emails/day, 3K/month)
# 1. Create an API key
RESEND_API_KEY=re_your-api-key

# ─── Application Secrets ─────────────────────────────────────────────
# Generate a random 256-bit secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-random-64-char-hex-string

# ─── Server Configuration ────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# For production, set your public URL:
API_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Rate Limiting ───────────────────────────────────────────────────
# Max API requests per window (per IP for anonymous, per user for authed)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── OSV.dev (Vulnerability Database — no key needed) ────────────────
# Public API, no signup required
OSV_API_URL=https://api.osv.dev

# ─── Feature Flags (all optional, defaults shown) ────────────────────
# Override any feature flag via env: FEATURE_FLAG_<NAME>=true|false
# FEATURE_FLAG_GHIN_CROWDSOURCE_REPORTS=true
# FEATURE_FLAG_GHIN_AUTO_CONFIRM=true
# FEATURE_FLAG_GHIN_BACKGROUND_CONSOLIDATION=true
# FEATURE_FLAG_SCAN_HISTORY_STORAGE=true
# FEATURE_FLAG_MEMORY_VERIFICATION=true
# FEATURE_FLAG_STRICT_TOOL_GATING=true
# FEATURE_FLAG_AI_TRIAGE_ASSISTANT=false
# FEATURE_FLAG_CONTINUOUS_MONITORING=false
# FEATURE_FLAG_AGENT_ORCHESTRATION=false

# ─── GHIN Consolidation (background daemon) ──────────────────────────
# How often the KAIROS-inspired consolidation runs (ms, default: 15 min)
# GHIN_CONSOLIDATION_INTERVAL_MS=900000

# ─── Optional: OpenAI (for LLM-powered deep SAST) ───────────────────
# Sign up: https://platform.openai.com (Free: $5 credit for new accounts)
# Only needed if you want LLM-powered code analysis
# OPENAI_API_KEY=sk-your-openai-key
